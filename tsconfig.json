{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": { "@/*": ["./src/*"] }
  },
  "exclude": ["src/main", "src/preload", "_electron_backup", "node_modules"]
}
