{
  "name": "lexio",
  "version": "1.0.0",
  "main": "dist-main/main/index.js",
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build": "tsc -p tsconfig.main.json && npm run build:renderer && electron-builder",
    "build:mac": "npm run build -- --mac",
    "build:win": "npm run build -- --win",
    "build:linux": "npm run build -- --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest": "npm rebuild better-sqlite3",
    "posttest": "npm run rebuild:electron",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "publish:win": "npm run build -- --win --publish always"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.3",
    "flag-icons": "^7.5.0",
    "i18next": "^25.10.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6"
  }
}
